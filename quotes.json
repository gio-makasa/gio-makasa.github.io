quote = `[{"q":"\\\"Enjoy the little things.\\\"","a":"zombieland (movie)"},
    {"q":"\\\"You can't get so hung up on where you'd rather be, that you forget to make the most of where you are.\\\"","a":"passengers (movie)"},
    {"q":"\\\"When you change your thoughts, remember to also change your world.\\\"","a":"Norman Vincent Peale"},
    {"q":"\\\"People often say that motivation doesn't last. Well, neither does bathing - that's why we recommend it daily.\\\"","a":"Zig Ziglar"},
    {"q":"\\\"Just one small positive thought in the morning can change your whole day.\\\"","a":"Dalai Lama"}
    ]`;